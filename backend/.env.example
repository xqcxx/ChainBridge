# =============================================================================
# ChainBridge Backend Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values
# NEVER commit .env file to version control
# =============================================================================

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_NAME=ChainBridge
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=info
ENVIRONMENT=development  # development, staging, production

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
PORT=8000
HOST=0.0.0.0

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Primary database (async for application)
DATABASE_URL=postgresql+asyncpg://chainbridge:password@localhost:5432/chainbridge

# Sync database (for migrations and admin tasks)
DATABASE_SYNC_URL=postgresql://chainbridge:password@localhost:5432/chainbridge

# Database connection pool settings
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_URL=redis://:password@localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# =============================================================================
# STELLAR / SOROBAN CONFIGURATION
# =============================================================================
# Network: testnet, mainnet
STELLAR_NETWORK=testnet

# Soroban RPC URL
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
SOROBAN_RPC_TIMEOUT=30

# Horizon RPC URL (for account info)
HORIZON_URL=https://horizon-testnet.stellar.org

# ChainBridge Contract Address
CHAINBRIDGE_CONTRACT_ID=

# Admin account for contract initialization
STELLAR_ADMIN_SECRET=

# =============================================================================
# BITCOIN CONFIGURATION
# =============================================================================
BITCOIN_NETWORK=testnet  # testnet, mainnet

# Bitcoin RPC
BITCOIN_RPC_URL=http://localhost:8332
BITCOIN_RPC_USER=
BITCOIN_RPC_PASSWORD=
BITCOIN_RPC_TIMEOUT=30

# Number of confirmations required
BITCOIN_CONFIRMATIONS=6

# =============================================================================
# ETHEREUM CONFIGURATION
# =============================================================================
ETHEREUM_NETWORK=testnet  # testnet, mainnet

# Ethereum RPC
ETHEREUM_RPC_URL=https://goerli.infura.io/v3/YOUR_INFURA_KEY
ETHEREUM_RPC_WS_URL=wss://goerli.infura.io/v3/YOUR_INFURA_KEY

# Ethereum WebSocket
ETHEREUM_CONFIRMATIONS=12

# HTLC Contract Address on Ethereum
ETHEREUM_HTLC_CONTRACT_ADDRESS=

# =============================================================================
# RELAYER CONFIGURATION
# =============================================================================
RELAYER_ENABLED=true

# Relayer fee (in basis points, e.g., 10 = 0.1%)
RELAYER_FEE_BPS=10
RELAYER_MIN_FEE=1000
RELAYER_MAX_FEE=100000

# =============================================================================
# SECURITY
# =============================================================================
# Secret key for session/token generation
SECRET_KEY=your-secret-key-here-change-in-production

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# API Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================
# Prometheus metrics
METRICS_ENABLED=true
METRICS_PORT=9090

# OpenTelemetry
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# =============================================================================
# EXTERNAL SERVICES (Optional)
# =============================================================================
# Price Oracle (for rate calculations)
PRICE_ORACLE_URL=
PRICE_ORACLE_API_KEY=

# Email notifications (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@chainbridge.io

# =============================================================================
# FEATURE FLAGS
# =============================================================================
FEATURE_SWAPS_ENABLED=true
FEATURE_ORDERS_ENABLED=true
FEATURE_ANALYTICS_ENABLED=true
FEATURE_NOTIFICATIONS_ENABLED=false
